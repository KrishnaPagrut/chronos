# Copy this file to .env and fill in your keys. .env is gitignored.

# Mapillary Graph API access token (starts with "MLY|").
# Create one at https://www.mapillary.com/dashboard/developers
# (register an app with read scope, then copy its Access Token).
MAPILLARY_TOKEN=

# OpenAI API key (starts with "sk-").
# Create one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: vision model used by `inspect` (default: gpt-4o).
OPENAI_MODEL=gpt-4o

# GPT-5.6 generates evidence-linked neighborhood summaries in the map UI.
BRIEF_MODEL=gpt-5.6-terra
